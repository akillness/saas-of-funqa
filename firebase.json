{
  "apphosting": [
    {
      "backendId": "saas-of-funqa",
      "rootDir": "apps/web",
      "ignore": [
        ".git",
        ".omc",
        ".omx",
        ".runtime",
        ".survey",
        "google-cloud-sdk",
        "google-cloud-cli-darwin-arm.tar.gz",
        "apps/web/.next",
        "apps/web/.turbo",
        "apps/web/package-lock.json",
        "node_modules",
        ".next",
        "dist",
        "coverage",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ],
      "alwaysDeployFromSource": true
    }
  ],
  "functions": [
    {
      "source": "functions",
      "codebase": "api",
      "runtime": "nodejs20",
      "ignore": [
        "node_modules",
        ".git",
        ".env",
        ".env.*",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "src",
        ".runtime"
      ],
      "predeploy": [
        "npm run build:functions"
      ]
    }
  ],
  "firestore": {
    "rules": "infra/firebase/firestore.rules",
    "indexes": "infra/firebase/firestore.indexes.json"
  },
  "storage": {
    "rules": "infra/firebase/storage.rules"
  },
  "emulators": {
    "functions": {
      "port": 5001
    },
    "apphosting": {
      "port": 5002
    },
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8080
    },
    "ui": {
      "enabled": false,
      "port": 4400
    }
  }
}
