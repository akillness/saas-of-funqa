{
  "apphosting": [
    {
      "backendId": "funqa-web",
      "rootDir": "apps/web",
      "ignore": [
        "node_modules",
        ".next",
        "dist",
        "coverage",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ],
  "firestore": {
    "rules": "infra/firebase/firestore.rules",
    "indexes": "infra/firebase/firestore.indexes.json"
  },
  "storage": {
    "rules": "infra/firebase/storage.rules"
  },
  "emulators": {
    "functions": {
      "port": 5001
    },
    "apphosting": {
      "port": 5002
    },
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8080
    },
    "ui": {
      "enabled": false,
      "port": 4400
    }
  }
}
